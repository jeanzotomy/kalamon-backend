# ============================================================
# KALAMON BACKEND — Variables d'environnement
# Copier en .env pour le dev local. En prod : secrets plateforme.
# ============================================================

# ── Serveur ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Origines autorisées (CORS), séparées par des virgules
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Base de données : PostgreSQL + pgvector ──────────────────
# Dev: Supabase OU postgres local. Prod: Azure Database for PostgreSQL.
# IMPORTANT: même moteur partout → "migration" = changer cette URL, rien d'autre.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kalamon?schema=public

# ── Auth : JWT httpOnly cookie (UN SEUL modèle d'auth) ──────
JWT_SECRET=change-me-en-prod-32-caracteres-minimum
JWT_EXPIRES_IN=7d
COOKIE_NAME=kalamon_token
# true en prod (HTTPS), false en dev local
COOKIE_SECURE=false

# ── IA : provider abstrait (RAG, pas chat ouvert) ────────────
# LLM_PROVIDER: anthropic | azure-openai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=
# Si LLM_PROVIDER=azure-openai :
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# ── Embeddings (pour le RAG / cache sémantique) ──────────────
# EMBEDDING_PROVIDER: openai | azure-openai
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
OPENAI_API_KEY=

# ── Garde-fous coût IA (budget tokens) ──────────────────────
# Plafond d'appels IA live par élève et par jour (anti-dérive de coût)
AI_DAILY_BUDGET_PER_STUDENT=120
# Seuil de similarité du cache sémantique (0-1) : au-dessus = cache hit
SEMANTIC_CACHE_THRESHOLD=0.92

# ── Paiement mobile money (CinetPay) ─────────────────────────
PAYMENT_PROVIDER=cinetpay
PAYMENT_CURRENCY=GNF
# URL PUBLIQUE de ce backend (le provider y poste la confirmation) :
#   webhook final appelé = {PAYMENT_NOTIFY_URL}/cinetpay
PAYMENT_NOTIFY_URL=https://api.kalamon.example/payments/webhook
# Où renvoyer le navigateur après paiement (page de ton app) :
PAYMENT_RETURN_URL=https://app.kalamon.example/paiement/retour
# Identifiants CinetPay (console CinetPay)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
# Tarif premium mensuel PAR DEVISE (unité majeure). La devise est dérivée du
# pays de l'utilisateur (GNF=Guinée, XOF=UEMOA, XAF=CEMAC). PAYMENT_CURRENCY sert
# de repli si le pays est inconnu.
PRICE_PREMIUM_MONTHLY_GNF=20000
PRICE_PREMIUM_MONTHLY_XOF=1000
PRICE_PREMIUM_MONTHLY_XAF=1000

# ── Stockage médias : Cloudflare R2 (S3-compatible, egress gratuit) ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kalamon
# URL publique du bucket (custom domain R2 ou r2.dev) pour servir les fichiers
R2_PUBLIC_BASE=

# ── Gamification ─────────────────────────────────────────────
# Points attribués par action pédagogique (constantes nommées, pas de valeur magique)
POINTS_PER_LESSON=10
POINTS_PER_QUIZ_CORRECT=5
