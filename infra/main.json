          "variables": {
            "acrName": "acrkalamon",
            "psqlName": "psql-kalamon",
            "psqlAdminLogin": "kalamonadmin",
            "psqlDbName": "kalamon",
            "logWorkspaceName": "log-kalamon",
            "caeEnvironmentName": "cae-kalamon",
            "containerAppName": "ca-kalamon-api",
            "acrLoginServer": "[format('{0}.azurecr.io', variables('acrName'))]",
            "containerImage": "[format('{0}/kalamon-backend:{1}', variables('acrLoginServer'), parameters('imageTag'))]",
            "commonTags": {
              "environment": "[parameters('environment')]",
              "project": "[parameters('project')]",
              "team": "[parameters('team')]",
              "managedBy": "bicep"
            }
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces",
              "apiVersion": "2023-09-01",
              "name": "[variables('logWorkspaceName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('commonTags')]",
              "properties": {
                "sku": {
                  "name": "PerGB2018"
                },
                "retentionInDays": 30,
                "features": {
                  "enableLogAccessUsingOnlyResourcePermissions": true
                }
              }
            },
            {
              "type": "Microsoft.ContainerRegistry/registries",
              "apiVersion": "2023-11-01-preview",
              "name": "[variables('acrName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('commonTags')]",
              "sku": {
                "name": "Basic"
              },
              "properties": {
                "adminUserEnabled": true,
                "publicNetworkAccess": "Enabled",
                "zoneRedundancy": "Disabled",
                "policies": {
                  "retentionPolicy": {
                    "days": 30,
                    "status": "enabled"
                  }
                }
              }
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers",
              "apiVersion": "2023-12-01-preview",
              "name": "[variables('psqlName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('commonTags')]",
              "sku": {
                "name": "[parameters('pgSku')]",
                "tier": "[parameters('pgSkuTier')]"
              },
              "properties": {
                "administratorLogin": "[variables('psqlAdminLogin')]",
                "administratorLoginPassword": "[parameters('pgAdminPassword')]",
                "version": "16",
                "storage": {
                  "storageSizeGB": 32,
                  "autoGrow": "Disabled"
                },
                "backup": {
                  "backupRetentionDays": 7,
                  "geoRedundantBackup": "Disabled"
                },
                "highAvailability": {
                  "mode": "Disabled"
                },
                "authConfig": {
                  "activeDirectoryAuth": "Disabled",
                  "passwordAuth": "Enabled"
                },
                "network": {
                  "publicNetworkAccess": "Enabled"
                }
              }
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/configurations",
              "apiVersion": "2023-12-01-preview",
              "name": "[format('{0}/{1}', variables('psqlName'), 'azure.extensions')]",
              "properties": {
                "value": "VECTOR",
                "source": "user-override"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('psqlName'))]"
              ]
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/firewallRules",
              "apiVersion": "2023-12-01-preview",
              "name": "[format('{0}/{1}', variables('psqlName'), 'AllowAllAzureServices')]",
              "properties": {
                "startIpAddress": "0.0.0.0",
                "endIpAddress": "0.0.0.0"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('psqlName'))]"
              ]
            },
            {
              "type": "Microsoft.DBforPostgreSQL/flexibleServers/databases",
              "apiVersion": "2023-12-01-preview",
              "name": "[format('{0}/{1}', variables('psqlName'), variables('psqlDbName'))]",
              "properties": {
                "charset": "UTF8",
                "collation": "en_US.utf8"
              },
              "dependsOn": [
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('psqlName'))]"
              ]
            },
            {
              "type": "Microsoft.App/managedEnvironments",
              "apiVersion": "2024-03-01",
              "name": "[variables('caeEnvironmentName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('commonTags')]",
              "properties": {
                "appLogsConfiguration": {
                  "destination": "log-analytics",
                  "logAnalyticsConfiguration": {
                    "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('logWorkspaceName')), '2023-09-01').customerId]",
                    "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('logWorkspaceName')), '2023-09-01').primarySharedKey]"
                  }
                },
                "zoneRedundant": false
              },
              "dependsOn": [
                "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logWorkspaceName'))]"
              ]
            },
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[variables('containerAppName')]",
              "location": "[parameters('location')]",
              "tags": "[variables('commonTags')]",
              "properties": {
                "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('caeEnvironmentName'))]",
                "configuration": {
                  "secrets": [
                    {
                      "name": "acr-password",
                      "value": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-11-01-preview').passwords[0].value]"
                    },
                    {
                      "name": "database-url",
                      "value": "[format('postgresql://{0}:{1}@{2}:5432/{3}?sslmode=require&schema=public', variables('psqlAdminLogin'), parameters('pgAdminPassword'), reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('psqlName')), '2023-12-01-preview').fullyQualifiedDomainName, variables('psqlDbName'))]"
                    },
                    {
                      "name": "jwt-secret",
                      "value": "[parameters('jwtSecret')]"
                    },
                    {
                      "name": "anthropic-api-key",
                      "value": "[parameters('anthropicApiKey')]"
                    },
                    {
                      "name": "openai-api-key",
                      "value": "[parameters('openAiApiKey')]"
                    },
                    {
                      "name": "cinetpay-api-key",
                      "value": "[parameters('cinetpayApiKey')]"
                    },
                    {
                      "name": "cinetpay-site-id",
                      "value": "[parameters('cinetpaySiteId')]"
                    },
                    {
                      "name": "cinetpay-secret-key",
                      "value": "[parameters('cinetpaySecretKey')]"
                    },
                    {
                      "name": "r2-access-key-id",
                      "value": "[parameters('r2AccessKeyId')]"
                    },
                    {
                      "name": "r2-secret-access-key",
                      "value": "[parameters('r2SecretAccessKey')]"
                    }
                  ],
                  "registries": [
                    {
                      "server": "[variables('acrLoginServer')]",
                      "username": "[listCredentials(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-11-01-preview').username]",
                      "passwordSecretRef": "acr-password"
                    }
                  ],
                  "ingress": {
                    "external": true,
                    "targetPort": 3000,
                    "transport": "auto",
                    "allowInsecure": false,
                    "traffic": [
                      {
                        "latestRevision": true,
                        "weight": 100
                      }
                    ]
                  },
                  "activeRevisionsMode": "Single"
                },
                "template": {
                  "containers": [
                    {
                      "name": "kalamon-api",
                      "image": "[variables('containerImage')]",
                      "resources": {
                        "cpu": "[json('0.5')]",
                        "memory": "1.0Gi"
                      },
                      "env": [
                        {
                          "name": "NODE_ENV",
                          "value": "production"
                        },
                        {
                          "name": "PORT",
                          "value": "3000"
                        },
                        {
                          "name": "CORS_ORIGINS",
                          "value": "[parameters('corsOrigins')]"
                        },
                        {
                          "name": "LLM_PROVIDER",
                          "value": "[parameters('llmProvider')]"
                        },
                        {
                          "name": "LLM_MODEL",
                          "value": "[parameters('llmModel')]"
                        },
                        {
                          "name": "EMBEDDING_PROVIDER",
                          "value": "[parameters('embeddingProvider')]"
                        },
                        {
                          "name": "EMBEDDING_MODEL",
                          "value": "[parameters('embeddingModel')]"
                        },
                        {
                          "name": "EMBEDDING_DIM",
                          "value": "[string(parameters('embeddingDim'))]"
                        },
                        {
                          "name": "AI_DAILY_BUDGET_PER_STUDENT",
                          "value": "[string(parameters('aiDailyBudgetPerStudent'))]"
                        },
                        {
                          "name": "SEMANTIC_CACHE_THRESHOLD",
                          "value": "[parameters('semanticCacheThreshold')]"
                        },
                        {
                          "name": "PAYMENT_PROVIDER",
                          "value": "[parameters('paymentProvider')]"
                        },
                        {
                          "name": "PAYMENT_CURRENCY",
                          "value": "[parameters('paymentCurrency')]"
                        },
                        {
                          "name": "PAYMENT_NOTIFY_URL",
                          "value": "[parameters('paymentNotifyUrl')]"
                        },
                        {
                          "name": "PAYMENT_RETURN_URL",
                          "value": "[parameters('paymentReturnUrl')]"
                        },
                        {
                          "name": "PRICE_PREMIUM_MONTHLY_GNF",
                          "value": "[string(parameters('pricePremiumMonthlyGnf'))]"
                        },
                        {
                          "name": "PRICE_PREMIUM_MONTHLY_XOF",
                          "value": "[string(parameters('pricePremiumMonthlyXof'))]"
                        },
                        {
                          "name": "PRICE_PREMIUM_MONTHLY_XAF",
                          "value": "[string(parameters('pricePremiumMonthlyXaf'))]"
                        },
                        {
                          "name": "R2_ACCOUNT_ID",
                          "value": "[parameters('r2AccountId')]"
                        },
                        {
                          "name": "R2_BUCKET",
                          "value": "[parameters('r2Bucket')]"
                        },
                        {
                          "name": "R2_PUBLIC_BASE",
                          "value": "[parameters('r2PublicBase')]"
                        },
                        {
                          "name": "POINTS_PER_LESSON",
                          "value": "[string(parameters('pointsPerLesson'))]"
                        },
                        {
                          "name": "POINTS_PER_QUIZ_CORRECT",
                          "value": "[string(parameters('pointsPerQuizCorrect'))]"
                        },
                        {
                          "name": "COOKIE_SECURE",
                          "value": "true"
                        },
                        {
                          "name": "COOKIE_NAME",
                          "value": "kalamon_token"
                        },
                        {
                          "name": "JWT_EXPIRES_IN",
                          "value": "7d"
                        },
                        {
                          "name": "DATABASE_URL",
                          "secretRef": "database-url"
                        },
                        {
                          "name": "JWT_SECRET",
                          "secretRef": "jwt-secret"
                        },
                        {
                          "name": "ANTHROPIC_API_KEY",
                          "secretRef": "anthropic-api-key"
                        },
                        {
                          "name": "OPENAI_API_KEY",
                          "secretRef": "openai-api-key"
                        },
                        {
                          "name": "CINETPAY_API_KEY",
                          "secretRef": "cinetpay-api-key"
                        },
                        {
                          "name": "CINETPAY_SITE_ID",
                          "secretRef": "cinetpay-site-id"
                        },
                        {
                          "name": "CINETPAY_SECRET_KEY",
                          "secretRef": "cinetpay-secret-key"
                        },
                        {
                          "name": "R2_ACCESS_KEY_ID",
                          "secretRef": "r2-access-key-id"
                        },
                        {
                          "name": "R2_SECRET_ACCESS_KEY",
                          "secretRef": "r2-secret-access-key"
                        }
                      ],
                      "probes": [
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000,
                            "scheme": "HTTP"
                          },
                          "initialDelaySeconds": 30,
                          "periodSeconds": 30,
                          "failureThreshold": 3,
                          "timeoutSeconds": 5
                        },
                        {
                          "type": "Readiness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000,
                            "scheme": "HTTP"
                          },
                          "initialDelaySeconds": 15,
                          "periodSeconds": 10,
                          "failureThreshold": 3,
                          "timeoutSeconds": 5
                        },
                        {
                          "type": "Startup",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000,
                            "scheme": "HTTP"
                          },
                          "initialDelaySeconds": 10,
                          "periodSeconds": 10,
                          "failureThreshold": 12,
                          "timeoutSeconds": 5
                        }
                      ]
                    }
                  ],
                  "scale": {
                    "minReplicas": 1,
                    "maxReplicas": 3,
                    "rules": [
                      {
                        "name": "http-scaling",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "20"
                          }
                        }
                      }
                    ]
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.ContainerRegistry/registries', variables('acrName'))]",
                "[resourceId('Microsoft.App/managedEnvironments', variables('caeEnvironmentName'))]",
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers/configurations', variables('psqlName'), 'azure.extensions')]",
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers/firewallRules', variables('psqlName'), 'AllowAllAzureServices')]",
                "[resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('psqlName'))]"
              ]
            }
          ],
          "outputs": {
            "containerAppFqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.App/containerApps', variables('containerAppName')), '2024-03-01').configuration.ingress.fqdn]"
            },
            "acrLoginServer": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', variables('acrName')), '2023-11-01-preview').loginServer]"
            },
            "postgresqlFqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.DBforPostgreSQL/flexibleServers', variables('psqlName')), '2023-12-01-preview').fullyQualifiedDomainName]"
            },
            "logWorkspaceId": {
              "type": "string",
              "value": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logWorkspaceName'))]"
            },
            "caeEnvironmentId": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/managedEnvironments', variables('caeEnvironmentName'))]"
            }
          }
        }
      },
      "dependsOn": [
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('rgName'))]"
      ]
    }
  ],
  "outputs": {
    "resourceGroupName": {
      "type": "string",
      "value": "[parameters('rgName')]"
    },
    "containerAppFqdn": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('rgName')), 'Microsoft.Resources/deployments', 'kalamon-resources'), '2025-04-01').outputs.containerAppFqdn.value]"
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('rgName')), 'Microsoft.Resources/deployments', 'kalamon-resources'), '2025-04-01').outputs.acrLoginServer.value]"
    },
    "postgresqlFqdn": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('rgName')), 'Microsoft.Resources/deployments', 'kalamon-resources'), '2025-04-01').outputs.postgresqlFqdn.value]"
    }
  }
