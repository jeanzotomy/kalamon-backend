        "description": "Points attribués par leçon complétée"
      }
    },
    "pointsPerQuizCorrect": {
      "type": "int",
      "defaultValue": 5,
      "metadata": {
        "description": "Points attribués par bonne réponse quiz"
      }
    },
    "corsOrigins": {
      "type": "string",
      "metadata": {
        "description": "Origines CORS autorisées (virgule-séparées)"
      }
    }
  },
